NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=https://app.dbin.ng
INVOICE_PREFIX=DBIN

# LCDBO governed snapshot endpoint. Use a cryptographically random value.
# Vercel Cron may use CRON_SECRET instead; the endpoint accepts either variable.
LCDBO_SNAPSHOT_SECRET=replace-with-a-long-random-secret

# Hostname routing (comma-separated values are supported).
DBIN_MARKETING_HOSTS=dbin.ng,www.dbin.ng
DBIN_APP_HOSTS=app.dbin.ng
DBIN_ADMIN_HOSTS=admin.dbin.ng
DBIN_VERIFY_HOSTS=verify.dbin.ng
DBIN_LOCAL_APP_HOSTS=localhost,127.0.0.1,::1

# Share the existing Supabase session across DBIN production subdomains.
# Leave unset in local development so localhost uses host-only cookies.
DBIN_AUTH_COOKIE_DOMAIN=.dbin.ng
